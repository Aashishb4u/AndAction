PROSPECT_DISCOVERY_CITY="Pune"
PROSPECT_DISCOVERY_STATE="Maharashtra"
PROSPECT_DISCOVERY_COUNTRY="India"
PROSPECT_DISCOVERY_GOOGLE_DOMAIN="google.co.in"
PROSPECT_DISCOVERY_HL="hi"
PROSPECT_DISCOVERY_GL="in"
PROSPECT_DISCOVERY_MAX_RESULTS="10"
PROSPECT_DISCOVERY_MEDIA_LIMIT="12"
PROSPECT_DISCOVERY_REQUEST_DELAY_MS="1000"
PROSPECT_DISCOVERY_START_INCREMENT="10"
PROSPECT_DISCOVERY_PAGES_PER_QUERY="5"
PROSPECT_DISCOVERY_RUNS_PER_DAY="10"
PROSPECT_DISCOVERY_DEBUG="false"

# Maps / Geocoding
# Map provider switch: "ola" (default) or "google"
MAP_CONFIG=ola
OLA_MAPS_API_KEY="your-ola-maps-api-key-here"
GOOGLE_MAPS_API_KEY="your-google-maps-api-key-here"

# VPS File Upload Configuration
VPS_UPLOAD_URL="http://72.62.227.114/api"
VPS_BASE_URL="http://72.62.227.114/uploads"
VPS_UPLOAD_SECRET="andaction-upload-secret-key-2026"
PUBLIC_UPLOAD_SECRET=""
