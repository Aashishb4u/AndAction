# Database Configuration
# Get your Neon.tech PostgreSQL connection string from: https://neon.tech
# Format: postgresql://[user]:[password]@[host]/[database]?sslmode=require
DATABASE_URL="postgresql://user:password@host.neon.tech/andaction?sslmode=require"

# NextAuth Configuration
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-here"
NEXTAUTH_URL="http://localhost:3001"

# OAuth Providers (for future use)
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# FACEBOOK_CLIENT_ID=""
# FACEBOOK_CLIENT_SECRET=""
# APPLE_CLIENT_ID=""
# APPLE_CLIENT_SECRET=""

# YouTube Integration
# Get your YouTube Data API v3 key from: https://console.cloud.google.com/apis/credentials
# This is required for connecting YouTube channels by name without OAuth
YOUTUBE_API_KEY="your-youtube-api-key-here"

# Cron Jobs
CRON_SECRET="your-cron-secret-here"
CRON_APP_URL="http://127.0.0.1:3000"
CRON_TIMEZONE="Asia/Kolkata"
CRON_REQUEST_TIMEOUT_MS="60000"
CRON_RUN_ON_STARTUP="false"

# Set to "true" to allow POST /api/admin/prospects without auth in production.
# Leave unset unless you are deliberately testing: it lets anyone create prospects.
ALLOW_PUBLIC_PROSPECT_IMPORT="false"

# Instagram Prospect Discovery
SERPAPI_KEY="your-serpapi-key-here"
PROSPECT_DISCOVERY_CATEGORY_TITLES='Live Band||Devotional Singer||Spiritual Singer||Singer||Anchor/Emcee/Host||DJ/VJ||DJ based Band||DJ Percussionist||Musician/Instrumentalist||Dancer/Dance group||Magicial/Illusionist||Comedian/Mimicry||Special act performer||Motivational speaker||Kids Entertainer||Folk Artist||Model'
