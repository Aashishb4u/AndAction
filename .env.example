# Database Configuration
# Get your Neon.tech PostgreSQL connection string from: https://neon.tech
# Format: postgresql://[user]:[password]@[host]/[database]?sslmode=require
DATABASE_URL="postgresql://user:password@host.neon.tech/andaction?sslmode=require"

# NextAuth Configuration
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-here"
NEXTAUTH_URL="http://localhost:3001"

# OAuth Providers (for future use)
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# FACEBOOK_CLIENT_ID=""
# FACEBOOK_CLIENT_SECRET=""
# APPLE_CLIENT_ID=""
# APPLE_CLIENT_SECRET=""

# YouTube Integration
# Get your YouTube Data API v3 key from: https://console.cloud.google.com/apis/credentials
# This is required for connecting YouTube channels by name without OAuth
YOUTUBE_API_KEY="your-youtube-api-key-here"

# Cron Jobs
CRON_SECRET="your-cron-secret-here"
CRON_APP_URL="http://127.0.0.1:3000"
CRON_TIMEZONE="Asia/Kolkata"
CRON_REQUEST_TIMEOUT_MS="60000"
CRON_RUN_ON_STARTUP="false"

# Instagram Prospect Discovery
SERPAPI_KEY="your-serpapi-key-here"
PROSPECT_DISCOVERY_QUERY='site:instagram.com "Instagram photos and videos" "spiritual singer"'
PROSPECT_DISCOVERY_QUERIES='site:instagram.com "Instagram photos and videos" "spiritual singer"||site:instagram.com "Instagram photos and videos" "devotional singer"'
PROSPECT_DISCOVERY_LOCATION="India"
PROSPECT_DISCOVERY_GOOGLE_DOMAIN="google.co.in"
PROSPECT_DISCOVERY_HL="hi"
PROSPECT_DISCOVERY_GL="in"
PROSPECT_DISCOVERY_MAX_RESULTS="10"
PROSPECT_DISCOVERY_MEDIA_LIMIT="12"
PROSPECT_DISCOVERY_REQUEST_DELAY_MS="1000"
PROSPECT_DISCOVERY_START_INCREMENT="10"
PROSPECT_DISCOVERY_PAGES_PER_QUERY="10"
PROSPECT_DISCOVERY_DEBUG="false"

# Maps / Geocoding
# Map provider switch: "ola" (default) or "google"
MAP_CONFIG=ola
OLA_MAPS_API_KEY="your-ola-maps-api-key-here"
GOOGLE_MAPS_API_KEY="your-google-maps-api-key-here"

# VPS File Upload Configuration
VPS_UPLOAD_URL="http://72.62.227.114/api"
VPS_BASE_URL="http://72.62.227.114/uploads"
VPS_UPLOAD_SECRET="andaction-upload-secret-key-2026"
PUBLIC_UPLOAD_SECRET=""
